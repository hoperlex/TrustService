# ── Сервер ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Слушать только localhost (наружу смотрит Nginx). Для доступа из локальной
# сети при разработке можно поставить 0.0.0.0.
HOST=127.0.0.1

# ── Подключение к PostgreSQL ────────────────────────────────────────────────
# Yandex Managed PostgreSQL (по аналогии с matcheck): порт 6432 — пулер,
# sslmode=verify-full — обязательная проверка сертификата сервера.
DATABASE_URL=postgresql://<user>:<password>@<host>.mdb.yandexcloud.net:6432/trustservice?sslmode=verify-full

# Путь к корневому сертификату Yandex CA (нужен для verify-full).
# Скачать: curl -o root.crt https://storage.yandexcloud.net/cloud-certs/CA.pem
# Локально:  infra/secrets/yandex-ca/root.crt
# На проде:  /srv/trustservice/secrets/yandex-ca/root.crt
# Для локального Postgres на localhost без TLS — оставить пустым.
DB_CA_CERT_PATH=/srv/trustservice/secrets/yandex-ca/root.crt

# ── Секрет сессии ───────────────────────────────────────────────────────────
# Просто длинная случайная строка (к БД отношения не имеет).
# Сгенерировать: openssl rand -hex 32
SESSION_SECRET=

# ── Публичный адрес сайта — для QR-кода на /print ───────────────────────────
PUBLIC_URL=https://trust.su10.ru

# ── Первичный сотрудник (создаётся при `npm run migrate`) ──────────────────
# После создания сотрудника ADMIN_PASSWORD можно убрать из окружения.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# ── Контакты в верхнем блоке публичной страницы ────────────────────────────
# Пустое значение = кнопка не показывается.
CONTACT_MAX=
CONTACT_TELEGRAM=
CONTACT_EMAIL=
CONTACT_PHONE=
