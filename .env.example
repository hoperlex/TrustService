# Подключение к PostgreSQL
DATABASE_URL=postgres://user:pass@localhost:5432/trustservice

# Секрет для подписи cookie-сессии сотрудника (задать случайной строкой)
SESSION_SECRET=change-me-to-a-long-random-string

# Публичный адрес сайта — используется для генерации QR-кода на /print
PUBLIC_URL=https://trust.su10.ru

# Порт приложения
PORT=3000

# Первичный сотрудник (создаётся при `npm run migrate`).
# После создания можно убрать ADMIN_PASSWORD из окружения.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Контакты в верхнем блоке публичной страницы.
# Пустое значение = кнопка не показывается.
CONTACT_MAX=
CONTACT_TELEGRAM=
CONTACT_EMAIL=
CONTACT_PHONE=
